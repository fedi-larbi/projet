<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="300.0" prefWidth="400.0">
    <TextField fx:id="nameField" layoutX="20.0" layoutY="20.0" promptText="Name" />
    <TextField fx:id="descriptionField" layoutX="20.0" layoutY="60.0" promptText="Description" />
    <TextField fx:id="iconField" layoutX="20.0" layoutY="100.0" promptText="Icon Link" />
    <CheckBox fx:id="redCheckbox" layoutX="20.0" layoutY="140.0" text="Red" />
    <CheckBox fx:id="blueCheckbox" layoutX="100.0" layoutY="140.0" text="Blue" />
    <CheckBox fx:id="greenCheckbox" layoutX="180.0" layoutY="140.0" text="Green" />
    <CheckBox fx:id="yellowCheckbox" layoutX="260.0" layoutY="140.0" text="Yellow" />
</AnchorPane>