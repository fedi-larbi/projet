<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.BulletinsController">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Tableau de bord" styleClass="nav-button" onAction="#handleDashboard"/>
                <Button text="📚  Gérer les Cours" styleClass="nav-button" onAction="#handleManageCourses"/>
                <Button text="📦  Gérer les Modules" styleClass="nav-button" onAction="#handleManageModules"/>
                <Button text="📝  Gérer Examens" styleClass="nav-button" onAction="#handleManageExams"/>
                <Button text="🛒  Boutique" styleClass="nav-button" onAction="#handleShopManagement"/>
                <Button text="📊  Bulletins" styleClass="nav-button active" onAction="#handleBulletins"/>
                <Button text="🏆  Certifications" styleClass="nav-button" onAction="#handleCertifications"/>
                <Button text="🤖  Analyse AI" styleClass="nav-button" onAction="#handleAnalysisAI"/>
                <Button text="👥  Gestion des Élèves" styleClass="nav-button" onAction="#handleStudentManagement"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <HBox styleClass="content-area" spacing="16">

            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <Label text="Gestion des Bulletins" styleClass="page-title"/>
                <Label fx:id="messageLabel" visible="false" wrapText="true"/>

                <TableView fx:id="gradesTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="studentIdColumn" text="Étudiant ID" prefWidth="110"/>
                        <TableColumn fx:id="subjectColumn" text="Matière" prefWidth="150"/>
                        <TableColumn fx:id="scoreColumn" text="Note" prefWidth="90"/>
                        <TableColumn fx:id="maxScoreColumn" text="Note Max" prefWidth="100"/>
                        <TableColumn fx:id="semesterColumn" text="Semestre" prefWidth="120"/>
                        <TableColumn fx:id="commentColumn" text="Appréciation" prefWidth="180"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucune note" style="-fx-text-fill: #94A3B8;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <VBox styleClass="card" spacing="12" minWidth="280" prefWidth="280" maxWidth="300">
                <Label text="Saisir une note" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>
                <Separator/>

                <VBox spacing="4">
                    <Label text="Étudiant" styleClass="form-label"/>
                    <ComboBox fx:id="studentComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Matière" styleClass="form-label"/>
                    <ComboBox fx:id="subjectComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Note *" styleClass="form-label"/>
                    <TextField fx:id="scoreField" promptText="Ex: 15.5" styleClass="text-field"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Note max" styleClass="form-label"/>
                    <TextField fx:id="maxScoreField" promptText="Ex: 20" styleClass="text-field"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Semestre" styleClass="form-label"/>
                    <ComboBox fx:id="semesterComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Appréciation" styleClass="form-label"/>
                    <TextField fx:id="commentField" promptText="Ex: Très bien" styleClass="text-field"/>
                </VBox>

                <Separator/>
                <Button text="➕ Ajouter" onAction="#handleCreate" styleClass="btn-primary" maxWidth="Infinity"/>
                <Button text="✏ Modifier" onAction="#handleUpdate" styleClass="btn-secondary" maxWidth="Infinity"/>
                <Button text="🗑 Supprimer" onAction="#handleDelete" styleClass="btn-danger" maxWidth="Infinity"/>
                <Button text="✖ Effacer" onAction="#handleClear" styleClass="btn-secondary" maxWidth="Infinity"/>
            </VBox>

        </HBox>
    </center>
</BorderPane>
