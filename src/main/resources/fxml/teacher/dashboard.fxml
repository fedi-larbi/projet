<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.TeacherDashboardController">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Tableau de bord" styleClass="nav-button active" onAction="#handleDashboard"/>
                <Button text="📚  Gérer les Cours" styleClass="nav-button" onAction="#handleManageCourses"/>
                <Button text="📦  Gérer les Modules" styleClass="nav-button" onAction="#handleManageModules"/>
                <Button text="📝  Gérer Examens" styleClass="nav-button" onAction="#handleManageExams"/>
                <Button text="🛒  Boutique" styleClass="nav-button" onAction="#handleShopManagement"/>
                <Button text="📊  Bulletins" styleClass="nav-button" onAction="#handleBulletins"/>
                <Button text="🏆  Certifications" styleClass="nav-button" onAction="#handleCertifications"/>
                <Button text="🤖  Analyse AI" styleClass="nav-button" onAction="#handleAnalysisAI"/>
                <Button text="👥  Gestion des Élèves" styleClass="nav-button" onAction="#handleStudentManagement"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox styleClass="content-area" spacing="24">

                <!-- Welcome Banner -->
                <VBox styleClass="welcome-banner" spacing="8">
                    <Label fx:id="welcomeLabel" text="Bienvenue, Enseignant! 👋" styleClass="welcome-title"/>
                    <Label text="Voici un résumé de votre activité aujourd'hui" styleClass="welcome-subtitle"/>
                </VBox>

                <!-- Statistics Cards -->
                <Label text="Statistiques" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <HBox spacing="16">
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label text="👥" styleClass="stat-icon"/>
                        <Label fx:id="studentsCountLabel" text="0" styleClass="stat-value"/>
                        <Label text="Étudiants" styleClass="stat-label"/>
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label text="📚" styleClass="stat-icon"/>
                        <Label fx:id="coursesCountLabel" text="0" styleClass="stat-value"/>
                        <Label text="Cours" styleClass="stat-label"/>
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label text="📝" styleClass="stat-icon"/>
                        <Label fx:id="examsCountLabel" text="0" styleClass="stat-value"/>
                        <Label text="Examens" styleClass="stat-label"/>
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label text="💰" styleClass="stat-icon"/>
                        <Label fx:id="revenueLabel" text="0 €" styleClass="stat-value"/>
                        <Label text="Revenus" styleClass="stat-label"/>
                    </VBox>
                </HBox>

                <!-- Quick Actions -->
                <Label text="Actions rapides" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <FlowPane hgap="16" vgap="8">
                    <Button text="➕ Nouveau cours" onAction="#handleManageCourses" styleClass="btn-primary" prefHeight="44"/>
                    <Button text="📝 Créer un examen" onAction="#handleManageExams" styleClass="btn-purple" prefHeight="44"/>
                    <Button text="👥 Gérer les élèves" onAction="#handleStudentManagement" styleClass="btn-secondary" prefHeight="44"/>
                    <Button text="🤖 Analyse AI" onAction="#handleAnalysisAI" styleClass="btn-secondary" prefHeight="44"/>
                </FlowPane>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
