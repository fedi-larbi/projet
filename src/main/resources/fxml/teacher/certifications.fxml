<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.CertificationsController">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Tableau de bord" styleClass="nav-button" onAction="#handleDashboard"/>
                <Button text="📚  Gérer les Cours" styleClass="nav-button" onAction="#handleManageCourses"/>
                <Button text="📦  Gérer les Modules" styleClass="nav-button" onAction="#handleManageModules"/>
                <Button text="📝  Gérer Examens" styleClass="nav-button" onAction="#handleManageExams"/>
                <Button text="🛒  Boutique" styleClass="nav-button" onAction="#handleShopManagement"/>
                <Button text="📊  Bulletins" styleClass="nav-button" onAction="#handleBulletins"/>
                <Button text="🏆  Certifications" styleClass="nav-button active" onAction="#handleCertifications"/>
                <Button text="🤖  Analyse AI" styleClass="nav-button" onAction="#handleAnalysisAI"/>
                <Button text="👥  Gestion des Élèves" styleClass="nav-button" onAction="#handleStudentManagement"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <HBox styleClass="content-area" spacing="16">

            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Gestion des Certifications" styleClass="page-title" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalLabel" style="-fx-text-fill: #64748B;"/>
                </HBox>
                <Label fx:id="messageLabel" visible="false" wrapText="true"/>

                <TableView fx:id="certificationsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="studentIdColumn" text="Étudiant ID" prefWidth="110"/>
                        <TableColumn fx:id="titleColumn" text="Titre" prefWidth="220"/>
                        <TableColumn fx:id="issueDateColumn" text="Date d'émission" prefWidth="140"/>
                        <TableColumn fx:id="statusColumn" text="Statut" prefWidth="110"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucune certification" style="-fx-text-fill: #94A3B8;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <VBox styleClass="card" spacing="12" minWidth="280" prefWidth="280" maxWidth="300">
                <Label text="Émettre un Certificat" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>
                <Separator/>

                <VBox spacing="4">
                    <Label text="Étudiant" styleClass="form-label"/>
                    <ComboBox fx:id="studentComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Cours" styleClass="form-label"/>
                    <ComboBox fx:id="courseComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Titre *" styleClass="form-label"/>
                    <TextField fx:id="titleField" promptText="Titre du certificat" styleClass="text-field"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Date d'émission" styleClass="form-label"/>
                    <DatePicker fx:id="issueDatePicker" maxWidth="Infinity" styleClass="date-picker"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Date d'expiration" styleClass="form-label"/>
                    <DatePicker fx:id="expiryDatePicker" maxWidth="Infinity" styleClass="date-picker"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Statut" styleClass="form-label"/>
                    <ComboBox fx:id="statusComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                </VBox>

                <Separator/>
                <Button text="🏆 Émettre" onAction="#handleIssue" styleClass="btn-primary" maxWidth="Infinity"/>
                <Button text="❌ Révoquer" onAction="#handleRevoke" styleClass="btn-danger" maxWidth="Infinity"/>
                <Button text="✖ Effacer" onAction="#handleClear" styleClass="btn-secondary" maxWidth="Infinity"/>
            </VBox>

        </HBox>
    </center>
</BorderPane>
