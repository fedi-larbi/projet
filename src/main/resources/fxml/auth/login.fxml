<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/21"
           styleClass="auth-container"
           fx:controller="com.edusmart.controller.auth.LoginController">

    <VBox alignment="CENTER" spacing="0">

        <!-- Logo / Branding -->
        <VBox alignment="CENTER" spacing="6">
            <padding><Insets bottom="32"/></padding>
            <Label text="🎓 EduSmart" styleClass="auth-logo"/>
            <Label text="Plateforme Éducative" style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;"/>
        </VBox>

        <!-- Login Card -->
        <VBox styleClass="auth-card" spacing="16" maxWidth="420">

            <Label text="Connexion" styleClass="auth-title"/>
            <Label text="Accédez à votre espace personnel" styleClass="auth-subtitle"/>

            <!-- Error Label -->
            <Label fx:id="errorLabel" styleClass="error-label" visible="false" wrapText="true"/>

            <!-- Email -->
            <VBox spacing="4">
                <Label text="Email" styleClass="form-label"/>
                <TextField fx:id="emailField" promptText="votre@email.com" styleClass="text-field"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="4">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Mot de passe" styleClass="form-label" HBox.hgrow="ALWAYS"/>
                    <Button text="Mot de passe oublié?" onAction="#handleForgotPassword"
                            style="-fx-background-color: transparent; -fx-text-fill: #2563EB; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 0;"/>
                </HBox>
                <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="password-field"/>
            </VBox>

            <!-- Remember Me -->
            <CheckBox fx:id="rememberMeCheckbox" text="Se souvenir de moi"
                      style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>

            <!-- Login Button -->
            <Button fx:id="loginButton" text="Se connecter" onAction="#handleLogin"
                    styleClass="btn-primary" maxWidth="Infinity" prefHeight="44"/>

            <!-- Separator -->
            <HBox alignment="CENTER" spacing="8" style="-fx-padding: 4 0;">
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="ou" style="-fx-text-fill: #94A3B8; -fx-font-size: 12px;"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Sign Up Link -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Pas encore de compte?" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
                <Button fx:id="signUpButton" text="Créer un compte" onAction="#handleSignUp"
                        style="-fx-background-color: transparent; -fx-text-fill: #1E3A8A; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 0;"/>
            </HBox>

        </VBox>

    </VBox>
</StackPane>
