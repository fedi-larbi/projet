<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/21"
           styleClass="auth-container"
           fx:controller="com.edusmart.controller.auth.SignUpController">

    <ScrollPane fitToWidth="true" fitToHeight="true"
                style="-fx-background: transparent; -fx-background-color: transparent;">

        <VBox alignment="CENTER" spacing="0" style="-fx-padding: 40 0;">

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="6">
                <padding><Insets bottom="24"/></padding>
                <Label text="🎓 EduSmart" styleClass="auth-logo"/>
                <Label text="Créer votre compte" style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;"/>
            </VBox>

            <!-- Sign Up Card -->
            <VBox styleClass="auth-card" spacing="14" maxWidth="440">

                <Label text="Inscription" styleClass="auth-title"/>
                <Label text="Rejoignez la communauté EduSmart" styleClass="auth-subtitle"/>

                <!-- Messages -->
                <Label fx:id="errorLabel" styleClass="error-label" visible="false" wrapText="true"/>
                <Label fx:id="successLabel" styleClass="success-label" visible="false" wrapText="true"/>

                <!-- First & Last Name -->
                <HBox spacing="12">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Prénom" styleClass="form-label"/>
                        <TextField fx:id="firstNameField" promptText="Ahmed" styleClass="text-field"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Nom" styleClass="form-label"/>
                        <TextField fx:id="lastNameField" promptText="Benali" styleClass="text-field"/>
                    </VBox>
                </HBox>

                <!-- Email -->
                <VBox spacing="4">
                    <Label text="Email" styleClass="form-label"/>
                    <TextField fx:id="emailField" promptText="votre@email.com" styleClass="text-field"/>
                </VBox>

                <!-- Role -->
                <VBox spacing="4">
                    <Label text="Rôle" styleClass="form-label"/>
                    <ComboBox fx:id="roleComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="4">
                    <Label text="Mot de passe" styleClass="form-label"/>
                    <PasswordField fx:id="passwordField" promptText="Minimum 6 caractères" styleClass="password-field"/>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="4">
                    <Label text="Confirmer le mot de passe" styleClass="form-label"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="••••••••" styleClass="password-field"/>
                </VBox>

                <!-- Terms -->
                <CheckBox fx:id="termsCheckbox"
                          text="J'accepte les conditions d'utilisation"
                          style="-fx-font-size: 12px; -fx-text-fill: #475569;"/>

                <!-- Register Button -->
                <Button fx:id="registerButton" text="Créer mon compte" onAction="#handleRegister"
                        styleClass="btn-primary" maxWidth="Infinity" prefHeight="44"/>

                <!-- Login Link -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Déjà un compte?" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
                    <Button fx:id="backToLoginButton" text="Se connecter" onAction="#handleBackToLogin"
                            style="-fx-background-color: transparent; -fx-text-fill: #1E3A8A; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 0;"/>
                </HBox>

            </VBox>

        </VBox>
    </ScrollPane>
</StackPane>
