<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.student.BulletinController">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Étudiant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="📚  Mes Cours" styleClass="nav-button" onAction="#handleCourses"/>
                <Button text="📝  Examens" styleClass="nav-button" onAction="#handleExams"/>
                <Button text="📊  Bulletin" styleClass="nav-button active" onAction="#handleBulletin"/>
                <Button text="🏆  Certifications" styleClass="nav-button" onAction="#handleCertification"/>
                <Button text="🛒  Boutique" styleClass="nav-button" onAction="#handleShop"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox styleClass="content-area" spacing="20">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="top-header">
                <Label text="Mon Bulletin de Notes" styleClass="page-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button fx:id="printButton" text="🖨 Imprimer" onAction="#handlePrint" styleClass="btn-secondary"/>
                <Button fx:id="downloadButton" text="⬇ Télécharger PDF" onAction="#handleDownload" styleClass="btn-primary"/>
            </HBox>

            <!-- Stats Row -->
            <HBox spacing="16">
                <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="📊" styleClass="stat-icon"/>
                    <Label fx:id="averageLabel" text="Moyenne: --" styleClass="stat-value" style="-fx-font-size: 18px;"/>
                    <Label text="Moyenne générale" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="🏆" styleClass="stat-icon"/>
                    <Label fx:id="rankLabel" text="Rang: --" styleClass="stat-value" style="-fx-font-size: 18px;"/>
                    <Label text="Classement" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <!-- Filters -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <ComboBox fx:id="semesterFilter" onAction="#handleFilterChange" styleClass="combo-box"/>
                <ComboBox fx:id="yearFilter" onAction="#handleFilterChange" styleClass="combo-box"/>
            </HBox>

            <!-- Grades Table -->
            <TableView fx:id="gradesTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="subjectColumn" text="Matière" prefWidth="200"/>
                    <TableColumn fx:id="scoreColumn" text="Note" prefWidth="100"/>
                    <TableColumn fx:id="maxScoreColumn" text="Note Max" prefWidth="100"/>
                    <TableColumn fx:id="semesterColumn" text="Semestre" prefWidth="120"/>
                    <TableColumn fx:id="commentColumn" text="Appréciation" prefWidth="200"/>
                </columns>
                <placeholder>
                    <Label text="Aucune note disponible" style="-fx-text-fill: #94A3B8;"/>
                </placeholder>
            </TableView>

        </VBox>
    </center>
</BorderPane>
