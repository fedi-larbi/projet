<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.student.ExamsController">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Étudiant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="📚  Mes Cours" styleClass="nav-button" onAction="#handleCourses"/>
                <Button text="📝  Examens" styleClass="nav-button active" onAction="#handleExams"/>
                <Button text="📊  Bulletin" styleClass="nav-button" onAction="#handleBulletin"/>
                <Button text="🏆  Certifications" styleClass="nav-button" onAction="#handleCertification"/>
                <Button text="🛒  Boutique" styleClass="nav-button" onAction="#handleShop"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox styleClass="content-area" spacing="20">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="top-header">
                <Label text="Examens &amp; Évaluations" styleClass="page-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalExamsLabel" style="-fx-text-fill: #64748B;"/>
            </HBox>

            <!-- Filters -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="🔍  Rechercher..." styleClass="search-bar" onAction="#handleSearch"/>
                <ComboBox fx:id="statusFilter" promptText="Statut" onAction="#handleFilterChange" styleClass="combo-box"/>
                <ComboBox fx:id="subjectFilter" promptText="Matière" onAction="#handleFilterChange" styleClass="combo-box"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Voir les détails" onAction="#handleViewExam" styleClass="btn-primary"/>
            </HBox>

            <!-- Exams Table -->
            <TableView fx:id="examsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="titleColumn" text="Titre" prefWidth="220"/>
                    <TableColumn fx:id="subjectColumn" text="Matière" prefWidth="140"/>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="120"/>
                    <TableColumn fx:id="durationColumn" text="Durée (min)" prefWidth="110"/>
                    <TableColumn fx:id="statusColumn" text="Statut" prefWidth="120"/>
                    <TableColumn fx:id="scoreColumn" text="Note" prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="Aucun examen trouvé" style="-fx-text-fill: #94A3B8;"/>
                </placeholder>
            </TableView>

        </VBox>
    </center>
</BorderPane>
